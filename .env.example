# Configuration de l'environnement pour le système SIRH

# ========== FRONTEND (Netlify / React) ==========
# À définir aussi dans Netlify > Environment variables (avant le build)
REACT_APP_API_URL=https://llmyrnodvjgwdpdiyagi.supabase.co/functions/v1
REACT_APP_SUPABASE_URL=https://llmyrnodvjgwdpdiyagi.supabase.co
REACT_APP_SUPABASE_ANON_KEY=votre-cle-anon-supabase

# Configuration ElevenLabs (optionnel)
REACT_APP_ELEVENLABS_API_KEY=your-elevenlabs-api-key-here

# ========== BACKEND LOCAL (optionnel) ==========
PORT=5000
NODE_ENV=development

# Base de données Supabase (PostgreSQL)
DB_USER=postgres
DB_HOST=db.llmyrnodvjgwdpdiyagi.supabase.co
DB_NAME=postgres
DB_PASSWORD=votre-mot-de-passe-base-supabase
DB_PORT=5432

SUPABASE_URL=https://llmyrnodvjgwdpdiyagi.supabase.co
SUPABASE_ANON_KEY=votre-cle-anon-supabase

# Emails (réinitialisation mot de passe)
SMTP_SERVICE=gmail
SMTP_USER=votre-email@gmail.com
SMTP_PASS=votre-mot-de-passe-app

# Sécurité
JWT_SECRET=your-super-secret-jwt-key-here-change-in-production
JWT_EXPIRES_IN=24h

# CORS
CORS_ORIGIN=http://localhost:3000
CORS_CREDENTIALS=true

# Sessions
SESSION_SECRET=your-session-secret-here-change-in-production
SESSION_MAX_AGE=86400000

# WebSocket
FRONTEND_URL=http://localhost:3000
